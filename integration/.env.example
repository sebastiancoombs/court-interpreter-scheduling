# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Easy!Appointments
EA_BASE_URL=http://localhost:8085
EA_ADMIN_API_TOKEN=
EA_DB_HOST=mysql
EA_DB_PORT=3306
EA_DB_NAME=easyappointments
EA_DB_USER=user
EA_DB_PASSWORD=password

# bcgov FastAPI
BCGOV_BASE_URL=http://localhost:8080

# Metabase
METABASE_SITE_URL=http://localhost:8088
METABASE_EMBEDDING_SECRET=

# Twilio — used by easyappointments/.../Sms_messages.php and the supabase/
# functions/sms-inbound edge function. SMS sending is GATED by TWILIO_ENABLED
# so the stack runs end-to-end without burning credentials. Flip to "true"
# only after the Twilio account + from-number are live.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_API_BASE_URL=https://api.twilio.com

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=interpreters@example.gov

# Service ports
AUTH_BRIDGE_PORT=8090
METABASE_SSO_PORT=8091
EA_SYNC_PORT=8092
